{
  "name": "audax",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "test": "turbo run test",
    "test:api": "pnpm --filter @audax/api test",
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @audax/api dev",
    "dev:web": "pnpm --filter @audax/web dev",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
