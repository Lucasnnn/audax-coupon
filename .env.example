# Copie para `.env` na raiz: `cp .env.example .env`
# Compartilhado por API, seed/migrate e Next (não precisa de `source` / export manual).

# --- Persistência ---
# Com DATABASE_URL: Postgres (ex.: banco via `pnpm docker:db`).
# Sem DATABASE_URL, ou com `pnpm dev:memory` (PERSISTENCE=memory): in-memory.
DATABASE_URL=postgresql://audax:audax@localhost:5432/audax
# PERSISTENCE=memory

PORT=3001

# URL da API no browser (Next). Padrão no código: http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
