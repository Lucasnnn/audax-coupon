{
  "name": "@audax/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest",
    "start:dev": "tsx watch src/main.ts",
    "dev": "tsx watch src/main.ts",
    "dev:memory": "cross-env PERSISTENCE=memory DATABASE_URL= tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/infrastructure/persistence/drizzle/run-migrate.ts",
    "db:seed": "tsx src/infrastructure/persistence/drizzle/run-seed.ts"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@audax/contracts": "workspace:^",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "3.25.76"
  }
